# =============================================================================
# personal-gpt - 环境变量模板
# =============================================================================
# 使用方法：
#   1. 复制本文件为 .env：       cp .env.example .env
#   2. 填入你自己的真实凭据（.env 已在 .gitignore 中，不会被提交）
#   3. 切勿将含有真实 token 的 .env 提交到任何远程仓库
# =============================================================================


# ----- Astra DB（向量数据库） -----
# 从 Astra Portal → 你的数据库 → Connect 页签 获取以下信息
# https://astra.datastax.com/

# Keyspace 名称（一般保持 default_keyspace 即可）
ASTRA_DB_NAMESPACE=default_keyspace

# 当前项目使用的集合（collection）名
ASTRA_DB_COLLECTION=db_emotion

# Data API endpoint（形如 https://<db-id>-<region>.apps.astra.datastax.com）
ASTRA_DB_API_ENDPOINT=https://<your-db-id>-<region>.apps.astra.datastax.com

# Application token（必须包含 r/w 权限；以 AstraCS: 开头）
ASTRA_DB_APPLICATION_TOKEN=AstraCS:<your-token-here>


# ----- OpenRouter（LLM + embedding 服务） -----
# 从 https://openrouter.ai/keys 获取
# 以 sk-or-v1- 开头
OPENROUTER_API_KEY=sk-or-v1-<your-key-here>
